# Audit Finding #93: .env.example listing all required environment variables
# Copy this file to .env and fill in real values

# WalletConnect project ID — get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# 0x Swap API key — get one at https://0x.org/
VITE_0X_API_KEY=your_0x_api_key_here

# Etherscan API key — get one at https://etherscan.io/apis
# AUDIT FIX H-23: Moved from hardcoded placeholder to env variable
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Alchemy API key — get one at https://dashboard.alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key_here
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here

# OpenSea API key — get one at https://docs.opensea.io
OPENSEA_API_KEY=your_opensea_api_key_here

# Supabase — get from https://supabase.com dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Push notifications (optional) — generate VAPID keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
