# Audit Finding #93: .env.example listing all required environment variables
# Copy this file to .env and fill in real values
#
# ───────────────────────────────────────────────────────────────────────
# IMPORTANT — SECRET HANDLING
#   • Client-side vars are prefixed VITE_* and ARE bundled into the JS ship.
#     Never put secrets you don't want public behind a VITE_ prefix.
#   • Server-only secrets (marked below) MUST live in Vercel Project Settings
#     → Environment Variables, and NEVER in a committed file.
#   • This template lists server-only keys as placeholders so contributors
#     know they exist; do not fill them in here.
# ───────────────────────────────────────────────────────────────────────

# ── Client-side (safe to bundle) ─────────────────────────────────────────

# WalletConnect project ID — get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# 0x Swap API key — get one at https://0x.org/
VITE_0X_API_KEY=your_0x_api_key_here

# Etherscan key moved to server-only section (R001 — was VITE_ prefixed).
# All Etherscan reads now go through /api/etherscan proxy.

# Alchemy — public read-only key for direct client reads (optional)
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here

# Supabase — ANON key is designed to be public with RLS enforcement
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Push notifications (optional) — generate VAPID keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Error & analytics endpoints (optional, public)
VITE_ERROR_ENDPOINT=
VITE_ANALYTICS_ENDPOINT=

# ── Server-only (set in Vercel dashboard; leave blank here) ──────────────
# DO NOT paste real values into this file. These are only referenced so new
# contributors know what /api routes expect. Values live in Vercel env only.

# Alchemy high-quota key used by the /api proxies
ALCHEMY_API_KEY=

# Etherscan API key — used by /api/etherscan proxy. NEVER use VITE_ prefix
# (that bundles secrets into client JS). Per R001, this was previously leaked
# via VITE_ prefix; rotate the key on etherscan.io and place new value in Vercel.
ETHERSCAN_API_KEY=

# OpenSea API key — used by /api/opensea
OPENSEA_API_KEY=

# Supabase service-role key — used by /api/auth/siwe for nonce storage
# NEVER exposed to the browser. Bypasses RLS. Treat as root credential.
SUPABASE_SERVICE_KEY=

# Supabase JWT secret — used to sign siwe_jwt cookies
# Identical to the secret visible in Supabase → Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# Upstash Redis for per-IP rate limiting on Vercel functions
# In production the limiter fails closed (503) when these are unset — required.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Canonical CORS origin used as the fallback when the request origin is
# not on the allow-list in each /api handler.
ALLOWED_ORIGIN=https://tegridyfarms.xyz
