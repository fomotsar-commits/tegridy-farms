// SPDX-License-Identifier: MIT
pragma solidity ^0.8.26;

import "forge-std/Test.sol";
import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import {PremiumAccess} from "../src/PremiumAccess.sol";

// ─── Mocks ──────────────────────────────────────────────────────────────

contract MockToweli is ERC20 {
    constructor() ERC20("Toweli", "TOWELI") { _mint(msg.sender, 1_000_000_000 ether); }
}

/// @dev USDC-style ERC-20: rejects transfers TO blocklisted addresses.
///      Models the M-02 attack vector where a recipient's blocklist status
///      bricks `safeTransfer` and would otherwise revert `cancelSubscription`.
contract MockBlocklistToken is ERC20 {
    mapping(address => bool) public blocked;
    address public admin;

    constructor() ERC20("BL", "BL") {
        admin = msg.sender;
        _mint(msg.sender, 1_000_000_000 ether);
    }

    function setBlocked(address who, bool b) external {
        require(msg.sender == admin, "not admin");
        blocked[who] = b;
    }

    function _update(address from, address to, uint256 value) internal override {
        // USDC pattern: reject if either side is blocklisted (we focus on `to`).
        require(!blocked[from] && !blocked[to], "BLOCKED");
        super._update(from, to, value);
    }
}

contract MockJBAC is ERC721 {
    uint256 private _nextId = 1;
    constructor() ERC721("JBAC", "JBAC") {}
    function mint(address to) external { _mint(to, _nextId++); }
}

// ─── R022 Test Suite ────────────────────────────────────────────────────

contract R022_PremiumAccessTest is Test {
    PremiumAccess premium;
    MockToweli toweli;
    MockJBAC jbac;

    address treasury = makeAddr("treasury");
    address alice = makeAddr("alice");
    address bob = makeAddr("bob");
    address carol = makeAddr("carol");
    address sweeper = makeAddr("sweeper");

    uint256 constant FEE = 100 ether;
    uint256 constant MONTH = 30 days;

    function setUp() public {
        toweli = new MockToweli();
        jbac = new MockJBAC();
        premium = new PremiumAccess(address(toweli), address(jbac), treasury, FEE);

        // Fund users
        toweli.transfer(alice, 10_000 ether);
        toweli.transfer(bob, 10_000 ether);
        toweli.transfer(carol, 10_000 ether);

        vm.prank(alice);
        toweli.approve(address(premium), type(uint256).max);
        vm.prank(bob);
        toweli.approve(address(premium), type(uint256).max);
        vm.prank(carol);
        toweli.approve(address(premium), type(uint256).max);
    }

    // ─── R022/H-01: Extension-then-cancel must NOT under-pay ──────────

    /// Pre-fix: subscribe 1 mo, wait 15 days, extend 1 mo, cancel immediately.
    /// User paid 200 (FEE*2), used 15/30 of period 1 = 50, owed 150. Pre-fix
    /// returned 100 (drift of 50). This test enforces 150 ± dust.
    function test_extend_then_cancel_fullRefund_NoDrift() public {
        // Period 1
        vm.prank(alice);
        premium.subscribe(1, FEE);

        // Halfway through period 1
        vm.warp(block.timestamp + 15 days);

        // Extend by another month
        vm.prank(alice);
        premium.subscribe(1, FEE);

        // Cancel immediately after extension.
        // remaining: period 1 has 15 days left of 30 (escrow 100) → 50 refundable
        //            period 2 has 30 days left of 30 (escrow 100) → 100 refundable
        // total refundable = 150
        vm.prank(alice);
        premium.cancelSubscription();

        // Pull-payment: claim
        vm.prank(alice);
        premium.claimRefund();

        // Alice paid 200, should be back to 9_950 ± 1 wei dust.
        // Started 10_000, paid 200 → 9_800. Refund 150 → 9_950.
        uint256 bal = toweli.balanceOf(alice);
        assertApproxEqAbs(bal, 9_950 ether, 2, "extend-then-cancel refund must equal sum of per-period pro-rata");
    }

    /// Multi-extension stress: 3 extensions over 3 different times, then cancel.
    /// Verifies the period-array math is exact across many extensions.
    function test_multipleExtensions_cancelMidPeriod_sumsCorrectly() public {
        // Pin start to 1 so arithmetic is unambiguous regardless of warp side-effects.
        vm.warp(1);
        vm.prank(alice);
        premium.subscribe(1, FEE); // p1: [1, 1+30d]

        vm.warp(1 + 10 days);
        vm.prank(alice);
        premium.subscribe(1, FEE); // p2: [1+30d, 1+60d]

        vm.warp(1 + 20 days);
        vm.prank(alice);
        premium.subscribe(1, FEE); // p3: [1+60d, 1+90d]

        // Cancel at 1+20d:
        // p1: remaining 10d / 30d * 100 = 33.33 ether
        // p2: full 100 (startedAt=1+30d > now)
        // p3: full 100
        // total = 233.33 ether
        vm.prank(alice);
        premium.cancelSubscription();
        vm.prank(alice);
        premium.claimRefund();

        uint256 bal = toweli.balanceOf(alice);
        uint256 p1Refund = (uint256(100 ether) * 10) / 30;
        uint256 expected = uint256(9_700 ether) + p1Refund + uint256(100 ether) + uint256(100 ether);
        assertApproxEqAbs(bal, expected, 2, "multi-extension cancel sums per-period correctly");
    }

    /// Pre-fix invariant kept: full-period cancel of single period still works exactly.
    function test_cancel_singlePeriod_halfwayThrough_proRata() public {
        vm.prank(alice);
        premium.subscribe(1, FEE);
        vm.warp(block.timestamp + 15 days);
        vm.prank(alice);
        premium.cancelSubscription();
        vm.prank(alice);
        premium.claimRefund();
        // Paid 100, used 50, refunded 50 → bal = 9_950
        assertApproxEqAbs(toweli.balanceOf(alice), 9_950 ether, 2, "single-period halfway pro-rata");
    }

    // ─── R022/H-02: sweepExpiredEscrow frees stranded escrow ───────────

    function test_sweepExpiredEscrow_FreesUnwithdrawable() public {
        // Two users subscribe, never cancel, just expire.
        vm.prank(alice);
        premium.subscribe(1, FEE);
        vm.prank(bob);
        premium.subscribe(1, FEE);

        // Pre-sweep: totalRefundEscrow == 200, withdrawable == 0
        assertEq(premium.totalRefundEscrow(), 200 ether, "pre-sweep escrow");

        // Move past expiry
        vm.warp(block.timestamp + 31 days);

        // Sweep
        uint256 sweeperBalBefore = toweli.balanceOf(sweeper);
        vm.prank(sweeper);
        (uint256 swept, uint256 freed, uint256 bounty) = premium.sweepExpiredEscrow(10);

        assertEq(swept, 2, "swept count");
        assertEq(freed, 200 ether, "freed escrow");
        assertEq(premium.totalRefundEscrow(), 0, "totalRefundEscrow after sweep");
        // Bounty: 0.10% of 200 = 0.2 ether
        assertEq(bounty, 0.2 ether, "bounty 10 bps");
        assertEq(toweli.balanceOf(sweeper), sweeperBalBefore + 0.2 ether, "sweeper paid bounty");

        // Treasury can now withdraw the rest.
        vm.prank(premium.owner());
        premium.withdrawToTreasury();
        // Treasury gets 200 - 0.2 = 199.8
        assertEq(toweli.balanceOf(treasury), 199.8 ether, "treasury after sweep+withdraw");
    }

    function test_sweepExpiredEscrow_RevertsOnZeroIterations() public {
        vm.expectRevert(PremiumAccess.ZeroIterations.selector);
        premium.sweepExpiredEscrow(0);
    }

    function test_sweepExpiredEscrow_NoExpired_NoBountyNoOp() public {
        vm.prank(alice);
        premium.subscribe(1, FEE);
        // Don't warp — alice is still active.
        vm.prank(sweeper);
        (uint256 swept, uint256 freed, uint256 bounty) = premium.sweepExpiredEscrow(10);
        assertEq(swept, 0);
        assertEq(freed, 0);
        assertEq(bounty, 0);
        assertEq(premium.totalRefundEscrow(), 100 ether, "active escrow untouched");
    }

    // ─── R022/M-02: Pull-payment survives blocklist ─────────────────────

    function test_cancelSubscription_BlocklistedUser_PullPattern() public {
        // Deploy a separate premium with the blocklist token to prove the pattern.
        MockBlocklistToken bt = new MockBlocklistToken();
        PremiumAccess premBl = new PremiumAccess(address(bt), address(jbac), treasury, FEE);
        bt.transfer(alice, 1_000 ether);
        vm.prank(alice);
        bt.approve(address(premBl), type(uint256).max);

        vm.prank(alice);
        premBl.subscribe(1, FEE);

        vm.warp(block.timestamp + 15 days);

        // Token-issuer adds alice to blocklist.
        bt.setBlocked(alice, true);

        // Cancel must NOT revert — pull-payment defers transfer.
        vm.prank(alice);
        premBl.cancelSubscription();

        // pendingRefund is credited.
        assertGt(premBl.pendingRefund(alice), 0, "refund credited despite blocklist");

        // Claim while blocklisted: token-side rejects.
        vm.prank(alice);
        vm.expectRevert();
        premBl.claimRefund();

        // After unblock, claim succeeds.
        bt.setBlocked(alice, false);
        uint256 before = bt.balanceOf(alice);
        vm.prank(alice);
        premBl.claimRefund();
        assertGt(bt.balanceOf(alice), before, "claim after unblock paid out");
        assertEq(premBl.pendingRefund(alice), 0, "pendingRefund cleared after claim");
    }

    function test_withdrawToTreasury_BlocklistedTreasury_AccruesPending() public {
        // Owner-blocklisted treasury: withdrawToTreasury must accrue not revert.
        MockBlocklistToken bt = new MockBlocklistToken();
        PremiumAccess premBl = new PremiumAccess(address(bt), address(jbac), treasury, FEE);
        bt.transfer(alice, 1_000 ether);
        vm.prank(alice);
        bt.approve(address(premBl), type(uint256).max);

        vm.prank(alice);
        premBl.subscribe(1, FEE);
        vm.warp(block.timestamp + 31 days);
        // sweep first to free escrow
        vm.prank(sweeper);
        premBl.sweepExpiredEscrow(10);

        // Block treasury
        bt.setBlocked(treasury, true);

        // withdrawToTreasury must NOT revert
        vm.prank(premBl.owner());
        premBl.withdrawToTreasury();

        assertGt(premBl.pendingTreasuryWithdrawal(), 0, "accrued for blocked treasury");

        // Unblock and call again — should drain.
        bt.setBlocked(treasury, false);
        vm.prank(premBl.owner());
        premBl.withdrawToTreasury();
        assertEq(premBl.pendingTreasuryWithdrawal(), 0, "drained after unblock");
        assertGt(bt.balanceOf(treasury), 0, "treasury received");
    }

    // ─── Sanity: claimRefund with no balance reverts ───────────────────

    function test_claimRefund_RevertsOnZero() public {
        vm.prank(alice);
        vm.expectRevert(PremiumAccess.NothingToClaim.selector);
        premium.claimRefund();
    }

    // ─── Sanity: hasPremium tracks period array correctly ──────────────

    function test_hasPremium_acrossExtension() public {
        vm.prank(alice);
        premium.subscribe(1, FEE);
        assertTrue(premium.hasPremium(alice));

        // Move to halfway, extend
        vm.warp(block.timestamp + 15 days);
        vm.prank(alice);
        premium.subscribe(1, FEE);
        assertTrue(premium.hasPremium(alice));
        assertEq(premium.periodCount(alice), 2, "two periods");

        // Move past first-period expiry but before second-period expiry → still active
        vm.warp(block.timestamp + 20 days); // total 35 days from start; period 2 expires at 30+30=60
        assertTrue(premium.hasPremium(alice), "still premium during extension period");

        // Move past everything
        vm.warp(block.timestamp + 30 days);
        assertFalse(premium.hasPremium(alice), "premium ends after final period");
    }
}
